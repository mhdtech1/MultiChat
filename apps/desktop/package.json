{
  "name": "@chatrix/desktop",
  "version": "1.0.10",
  "private": true,
  "type": "module",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"tsc -p tsconfig.main.json --watch --preserveWatchOutput\" \"electron dist/main/main.js\"",
    "build": "pnpm run build:renderer && pnpm run build:main && pnpm run package",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "package": "pnpm run package:mac",
    "package:mac": "pnpm run package:mac:universal",
    "package:mac:universal": "electron-builder --config electron-builder.yml --mac dir --universal && MAC_BUILD_ARCH=universal node ../../scripts/prepare-mac-update-artifacts.mjs",
    "package:mac:arm64": "electron-builder --config electron-builder.yml --mac dir --arm64 && MAC_BUILD_ARCH=arm64 node ../../scripts/prepare-mac-update-artifacts.mjs",
    "package:mac:x64": "electron-builder --config electron-builder.yml --mac dir --x64 && MAC_BUILD_ARCH=x64 MAC_ARTIFACT_SUFFIX=x64 node ../../scripts/prepare-mac-update-artifacts.mjs",
    "package:win": "pnpm run package:win:web",
    "package:win:web": "electron-builder --config electron-builder.yml --win nsis-web --x64 --arm64 && node ../../scripts/prepare-win-update-artifacts.mjs",
    "package:win:x64": "electron-builder --config electron-builder.yml --win nsis --x64 && node ../../scripts/prepare-win-update-artifacts.mjs",
    "package:win:arm64": "electron-builder --config electron-builder.yml --win nsis --arm64 && node ../../scripts/prepare-win-update-artifacts.mjs",
    "package:linux": "electron-builder --config electron-builder.yml --linux AppImage deb --x64",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:smoke": "node ../../scripts/smoke-test.mjs",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "format": "prettier --check \"src/**/*.{ts,tsx,css,html}\""
  },
  "dependencies": {
    "@chatrix/chat-core": "workspace:*",
    "@tanstack/react-virtual": "^3.13.19",
    "argparse": "^2.0.1",
    "builder-util-runtime": "9.5.1",
    "debug": "^4.3.7",
    "electron-updater": "^6.3.9",
    "fs-extra": "^10.1.0",
    "graceful-fs": "^4.2.11",
    "js-yaml": "^4.1.0",
    "jsonfile": "^6.1.0",
    "keytar": "^7.9.0",
    "lazy-val": "^1.0.5",
    "lodash.escaperegexp": "^4.1.2",
    "lodash.isequal": "^4.5.0",
    "ms": "^2.1.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sax": "^1.4.1",
    "semver": "~7.7.3",
    "tiktok-live-connector": "2.1.1-beta1",
    "tiny-typed-emitter": "^2.1.0",
    "universalify": "^2.0.1",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20.14.10",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.0.1",
    "electron": "31.7.7",
    "electron-builder": "^24.13.3",
    "eslint": "^9.7.0",
    "eslint-config-prettier": "^9.1.0",
    "jsdom": "^28.1.0",
    "lru-cache": "^11.2.6",
    "prettier": "^3.3.3",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.56.1",
    "vite": "^5.3.4",
    "vitest": "^2.0.5"
  }
}
