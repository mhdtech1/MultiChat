# Example environment variables
VITE_DEV_SERVER_URL=http://localhost:5173

# Twitch OAuth
TWITCH_CLIENT_ID=
TWITCH_REDIRECT_URI=http://localhost:51730/twitch/callback

# Kick OAuth
KICK_CLIENT_ID=
KICK_CLIENT_SECRET=
KICK_REDIRECT_URI=http://localhost:51730/kick/callback
# Optional backend token broker for public desktop builds.
# When both URLs are set, Chatrix exchanges and refreshes Kick tokens through the broker
# instead of shipping a Kick client secret in the app.
KICK_TOKEN_BROKER_EXCHANGE_URL=
KICK_TOKEN_BROKER_REFRESH_URL=
# Optional local settings for running the broker service itself.
KICK_BROKER_HOST=127.0.0.1
KICK_BROKER_PORT=3001
KICK_BROKER_ALLOWED_REDIRECT_PREFIXES=http://localhost:51730/,http://127.0.0.1:51730/
# Hosted platforms like Render usually inject PORT automatically and should bind to 0.0.0.0.

# YouTube (alpha feature)
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=http://localhost:51730/youtube/callback
YOUTUBE_API_KEY=

# TikTok LIVE (alpha feature)
# Required to enable TikTok message sending. Obtain from the TikTok sign API provider.
TIKTOK_SIGN_API_KEY=
